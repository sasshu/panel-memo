{
  "manifest_version": 3,
  "name": "パネルメモ",
  "description": "サイドパネルで編集できるメモ帳",
  "version": "1.1",
  "icons": {
    "16": "memo-editing_16.png",
    "48": "memo-editing_48.png",
    "128": "memo-editing_128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "unlimitedStorage"
  ],
  "action": {
    "default_title": "パネルメモ",
    "default_icon": "memo-editing_48.png"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
